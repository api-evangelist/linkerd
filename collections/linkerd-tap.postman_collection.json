  "info": {
    "_postman_id": "c1e25339-dce0-4652-b549-3df726e28706",
    "name": "Linkerd Tap API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Linkerd Tap API is a Kubernetes aggregated API server that provides real-time streaming access to requests flowing through the Linkerd service mesh. It allows live inspection of HTTP and gRPC traffic including headers, paths, response codes, and latency. Access is controlled via Kubernetes RBAC on the tap.linkerd.io API group.\n\nContact Support:\n Name: Linkerd",
      "type": "text/plain"
    }
  }
